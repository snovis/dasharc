# ─── App Config ──────────────────────────────────────────────
# Company/tenant display name shown in the UI
VITE_APP_NAME=DashARC
VITE_COMPANY_NAME=SalesARC

# ─── Firebase ────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Feature Flags ───────────────────────────────────────────
# Set to "true" to use mock data instead of Firestore (for development)
VITE_USE_MOCK_DATA=true

# ─── Ingest Function (server-side only — NO VITE_ prefix) ────
# Credentials the /api/ingest Vercel function uses to sign in as the
# dedicated Firebase Auth user that is allowed to write to calls/*.
# Create this user in Firebase console → Authentication → Users.
INGEST_EMAIL=
INGEST_PASSWORD=

# Shared secret that n8n must send as X-Ingest-Secret header.
# Generate with: openssl rand -hex 32
INGEST_SECRET=
