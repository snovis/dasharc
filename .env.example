# ─── App Config ──────────────────────────────────────────────
# Display strings in the UI. Safe to ship to the browser.
VITE_APP_NAME=DashARC
VITE_COMPANY_NAME=SalesARC

# ─── Google Sign-In (client-side) ────────────────────────────
# OAuth 2.0 Client ID from Google Cloud Console → APIs & Services → Credentials.
# Must end with `.apps.googleusercontent.com`. Needs authorized JavaScript
# origins configured for http://localhost:5173, http://localhost:3000, and
# the production Vercel URL.
VITE_GOOGLE_CLIENT_ID=

# ─── Synthflow API (server-side, secret) ─────────────────────
# Never prefix with VITE_ — would leak into the browser bundle.
# Used by Vercel serverless functions in /api to proxy Synthflow requests.
# Get from Synthflow dashboard → API keys.
SYNTHFLOW_API_KEY=

# ─── Access Control (server-side) ────────────────────────────
# Comma-separated Google-account emails permitted to use this deployment.
# Whitespace trimmed, compared case-insensitively. Anyone not on this list
# will see a 403 after signing in with Google.
ALLOWED_EMAILS=

# Comma-separated Synthflow agent (model_id) UUIDs this deployment surfaces.
# The client only sees calls/agents for IDs in this list. Restrict per-client:
# e.g. a SalesARC→OnSite Medical deployment lists only that agent's ID.
AGENT_IDS=
