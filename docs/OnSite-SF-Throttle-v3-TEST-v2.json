        "jsCode": "// F4 FIX: Reset static data to prevent stale data from crashed runs\nconst staticData = $getWorkflowStaticData('global');\nstaticData.allRecords = '[]';\nconsole.log('[RESET] Static data cleared');\nreturn [{ json: { reset: true } }];"
