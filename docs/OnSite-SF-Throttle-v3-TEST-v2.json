        "url": "https://onsitemedical2.my.salesforce.com/services/data/v59.0/query/",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "salesforceOAuth2Api",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "q",
              "value": "SELECT Id, Phone, FirstName, LastName, Company, State, AI_Call_Status__c, AI_Call_Date__c, AI_Campaign__c FROM Lead WHERE Phone != null AND (AI_Call_Status__c = null OR AI_Call_Status__c = 'Not_Called') AND Status IN ('New', 'Qualified') AND IsConverted = false AND AI_Call_Engage__c = true ORDER BY CreatedDate ASC"
            }
          ]
        },
