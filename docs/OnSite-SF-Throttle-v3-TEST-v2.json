    {
      "parameters": {
        "jsCode": "const currentBatch = $input.first().json;\n\nlet allRecords = [];\ntry {\n  allRecords = JSON.parse($getWorkflowStaticData('global').allRecords || '[]');\n} catch(e) {\n  allRecords = [];\n}\n\nif (currentBatch.records && currentBatch.records.length > 0) {\n  allRecords = allRecords.concat(currentBatch.records);\n}\n\nconst staticData = $getWorkflowStaticData('global');\nstaticData.allRecords = JSON.stringify(allRecords);\n\nreturn [{\n  json: {\n    totalSize: currentBatch.totalSize,\n    done: currentBatch.done,\n    nextRecordsUrl: currentBatch.nextRecordsUrl || null,\n    recordsCollected: allRecords.length,\n    currentBatchSize: currentBatch.records ? currentBatch.records.length : 0\n  }\n}];"
      },
