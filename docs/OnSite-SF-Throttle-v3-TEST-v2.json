    {
      "parameters": {
        "jsCode": "const err = $input.first().json;\nconsole.error('[PAGINATION ERROR] Failed to fetch next page:', JSON.stringify(err));\n// Continue to Process Leads with whatever we have so far\nreturn [{ json: { paginationError: true, details: err } }];"
      },
      "id": "f6604370-b04f-452b-8ddf-d20b14885bf5",
      "name": "Log Pagination Error",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst allRecords = JSON.parse(staticData.allRecords || '[]');\nstaticData.allRecords = '[]';\n\nconsole.log('Total records from SF:', allRecords.length);\n\nconst AZ_CODES = new Set([\"480\", \"520\", \"602\", \"623\", \"928\"]);\nconst TX_CODES = new Set([\"210\", \"214\", \"254\", \"281\", \"325\", \"361\", \"409\", \"430\", \"432\", \"469\", \"512\", \"682\", \"713\", \"726\", \"737\", \"806\", \"817\", \"830\", \"832\", \"903\", \"915\", \"936\", \"940\", \"956\", \"972\", \"979\"]);\n\nlet skippedInvalidFormat = 0;\nlet skippedDualPhone = 0;\nlet skippedUnknownRegion = 0;\nconst invalidPhoneDetails = [];\nconst validContacts = [];\n\nfor (const lead of allRecords) {\n  let phone = lead.Phone || '';\n  \n  // Handle dual phones - take first\n  if (phone.includes('/')) {\n    phone = phone.split('/')[0].trim();\n    skippedDualPhone++;\n  }\n  \n  // Strip everything except digits and +\n  phone = phone.replace(/[^\\d+]/g, '');\n  \n  // Normalize to E.164\n  if (/^\\d{10}$/.test(phone)) {\n    phone = '+1' + phone;\n  } else if (/^1\\d{10}$/.test(phone)) {\n    phone = '+' + phone;\n  }\n  \n  // Validate E.164 US\n  if (!/^\\+1[2-9]\\d{9}$/.test(phone)) {\n    skippedInvalidFormat++;\n    invalidPhoneDetails.push({\n      name: (lead.FirstName || '') + ' ' + (lead.LastName || ''),\n      original: lead.Phone,\n      normalized: phone,\n      id: lead.Id\n    });\n    continue;\n  }\n  \n  // Area code -> campaign\n  const areaCode = phone.substring(2, 5);\n  const state = (lead.State || '').toUpperCase().trim();\n  \n  let campaign = '';\n  if (state === 'AZ' || state === 'ARIZONA' || AZ_CODES.has(areaCode)) {\n    campaign = 'AZ_CrossSell';\n  } else if (state === 'TX' || state === 'TEXAS' || TX_CODES.has(areaCode)) {\n    campaign = 'TX_ColdOutreach';\n  } else {\n    // F3 FIX: Skip UNKNOWN — don't call leads outside AZ/TX\n    skippedUnknownRegion++;\n    console.log('[SKIP] Unknown region:', lead.FirstName, lead.LastName, '| Phone:', lead.Phone, '| Area:', areaCode, '| State:', lead.State);\n    continue;\n  }\n  \n  validContacts.push({\n    json: {\n      id: lead.Id,\n      phone: phone,\n      firstName: lead.FirstName || '',\n      lastName: lead.LastName || '',\n      company: lead.Company || '',\n      state: lead.State || '',\n      areaCode: areaCode,\n      campaign: campaign\n    }\n  });\n}\n\nconst azCount = validContacts.filter(c => c.json.campaign === 'AZ_CrossSell').length;\nconst txCount = validContacts.filter(c => c.json.campaign === 'TX_ColdOutreach').length;\n\nconsole.log('=== PROCESSING SUMMARY ===');\nconsole.log('Total from SF:', allRecords.length);\nconsole.log('Dual phones (took first):', skippedDualPhone);\nconsole.log('Skipped invalid format:', skippedInvalidFormat);\nconsole.log('Skipped unknown region:', skippedUnknownRegion);\nconsole.log('Valid contacts:', validContacts.length);\nconsole.log('  AZ Cross-Sell:', azCount);\nconsole.log('  TX Cold Outreach:', txCount);\nif (invalidPhoneDetails.length > 0) {\n  console.log('Invalid phones:', JSON.stringify(invalidPhoneDetails));\n}\n\nif (validContacts.length === 0) {\n  return [{ json: { noContacts: true } }];\n}\n\nreturn validContacts;"
      },
